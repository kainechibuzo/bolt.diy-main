# Ignore Git and GitHub files
.git
.github/

# Ignore Husky configuration files
.husky/

# Ignore documentation and metadata files
CONTRIBUTING.md
LICENSE
README.md

# Ignore environment examples and sensitive info
.env
*.local
*.example

# Ignore node modules, logs and cache files
**/*.log
**/node_modules
**/dist
**/.cache
logs
dist-ssr
.DS_Store

# Ignore Electron / Wrangler / test artifacts not needed at runtime
electron/
.wrangler/
.vercel/
docs/
tests/

# NOTE: The `build/` directory is INTENTIONALLY NOT IGNORED.
# The Dockerfile copies the pre-compiled `build/` output into the runtime
# image instead of running `pnpm run build` inside the container.
# Only ignore Cloudflare Pages functions build output:
functions/build/
!build
!build/**
