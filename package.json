{
  "name": "bolt",
  "description": "An AI Agent",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "version": "1.0.0",
  "author": {
    "name": "bolt.diy team",
    "email": "maintainers@bolt.diy"
  },
  "scripts": {
    "deploy": "pnpm run build && wrangler pages deploy ./build/client",
    "build": "remix vite:build",
    "dev": "node pre-start.cjs && remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "preview": "pnpm run build && pnpm run start",
    "typecheck": "tsc",
    "typegen": "wrangler types",
    "clean": "rimraf build node_modules/.cache",
    "dockerbuild": "docker build -t bolt-ai:development -t bolt-ai:latest --target development .",
    "dockerbuild:prod": "docker build -t bolt-ai:production -t bolt-ai:latest --target bolt-ai-production .",
    "dockerrun": "docker run --rm -p 5173:5173 --env-file .env.local bolt-ai:latest",
    "dockerstart": "remix-serve ./build/server/index.js"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "latest",
    "@ai-sdk/anthropic": "latest",
    "@ai-sdk/cohere": "latest",
    "@ai-sdk/google": "latest",
    "@ai-sdk/groq": "latest",
    "@ai-sdk/mistral": "latest",
    "@ai-sdk/openai": "latest",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.35.0",
    "@iconify-json/ph": "^1.2.1",
    "@lezer/highlight": "^1.2.1",
    "@octokit/rest": "^21.0.2",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@remix-run/cloudflare": "^2.15.2",
    "@remix-run/cloudflare-pages": "^2.15.2",
    "@remix-run/node": "^2.15.2",
    "@remix-run/react": "^2.15.2",
    "@remix-run/serve": "^2.15.2",
    "@unocss/reset": "^0.65.1",
    "@webcontainer/api": "1.3.0-internal-webcontainer-api-local-wasm.1",
    "ai": "latest",
    "date-fns": "^4.1.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.7",
    "framer-motion": "^11.13.5",
    "isbot": "^4.4.0",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^2.1.7",
    "react-toastify": "^10.0.6",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "sacb": "^1.1.2",
    "sharp": "^0.33.5",
    "status": "^1.0.0",
    "toast": "^0.5.4",
    "ua-parser-js": "^2.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@remix-run/dev": "^2.15.2",
    "@types/diff": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ua-parser-js": "^0.7.39",
    "chromadb": "^1.10.0",
    "fast-glob": "^3.3.2",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "sass-embedded": "^1.82.0",
    "typescript": "^5.7.2",
    "unocss": "^0.65.1",
    "vite": "^6.0.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-optimize-css-modules": "^1.1.1",
    "vite-plugin-pwa": "^0.21.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "wrangler": "^3.93.0"
  }
}
